# Paramodus — environment variable reference
# Copy to .env and fill in values as needed.
# This file is safe to commit. .env is gitignored.

# ── Language ──────────────────────────────────────────────────────────────────
# Persisted by the Settings panel. Values: en | fr | es | de | pt | zh
PARAMODUS_LANGUAGE=en

# ── Google Workspace (all optional) ───────────────────────────────────────────
# Set to "true" to enable each service. Requires credentials.json + token.json.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_GMAIL_ENABLED=false
GOOGLE_CONTACTS_ENABLED=false
GOOGLE_DRIVE_ENABLED=false

# ── Model variant ─────────────────────────────────────────────────────────────
# Which Bonsai model to load at startup. Values: 8b | 4b | 1.7b
PARAMODUS_MODEL_VARIANT=8b
